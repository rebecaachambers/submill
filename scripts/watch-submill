#!/bin/bash
# =============================================================================
# SubMill Worker - 监听 SubMill 输出，转换后同步到 Mihomo
# =============================================================================
set -e

# 路径配置：由 setup.sh 安装时替换为实际路径
SUBS_OUTPUT="${SUBS_OUTPUT:-/opt/submill/output/all.yaml}"
MIHOMO_NODES="${MIHOMO_NODES:-/opt/submill/mihomo/nodes}"
SYNC_SCRIPT="${SYNC_SCRIPT:-/opt/submill/scripts/sync-mihomo-nodes}"
LOCK_FILE="/tmp/watch-submill.lock"

# 防止重复运行
exec 200>"$LOCK_FILE"
flock -n 200 || { echo "[WARN] watch-submill 已在运行，退出"; exit 0; }

echo "[$(date '+%Y-%m-%d %H:%M:%S')] watch-submill Worker 启动"
echo "  监听文件: $SUBS_OUTPUT"
echo "  目标目录: $MIHOMO_NODES"
echo "  同步脚本: $SYNC_SCRIPT"

# 首次启动先同步一次
if [ -f "$SUBS_OUTPUT" ]; then
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] 首次同步..."
    bash "$SYNC_SCRIPT" "$SUBS_OUTPUT" "$MIHOMO_NODES"
fi

# 持续监听
while inotifywait -q -e close_write,moved_to "$SUBS_OUTPUT" 2>/dev/null; do
    sleep 1
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] 检测到节点文件变化，开始同步..."
    bash "$SYNC_SCRIPT" "$SUBS_OUTPUT" "$MIHOMO_NODES"
done