#!/bin/bash
# =============================================================================
# sync-mihomo-nodes - 将 SubMill 节点转换为 Mihomo 格式并写入目标目录
# 用法: sync-mihomo-nodes <源文件> <目标目录>
# =============================================================================
set -e

SOURCE="$1"
TARGET_DIR="$2"

if [ -z "$SOURCE" ] || [ -z "$TARGET_DIR" ]; then
    echo "用法: sync-mihomo-nodes <源文件> <目标目录>"
    exit 1
fi

if [ ! -f "$SOURCE" ]; then
    echo "[ERROR] 源文件不存在: $SOURCE"
    exit 1
fi

mkdir -p "$TARGET_DIR"

TARGET_FILE="$TARGET_DIR/all.yaml"
TEMP_FILE="$TARGET_DIR/all.yaml.tmp"

# 将 SubMill 输出的 proxies 列表转换为 Mihomo 可读取的格式
# SubMill 输出格式:
#   proxies:
#     - name: ...
#       type: ...
#       server: ...
#       port: ...
#
# Mihomo file provider 兼容同样格式,只需确保文件完整性
python3 -c "
import yaml
import sys
import os
import json

try:
    with open('$SOURCE', 'r', encoding='utf-8') as f:
        data = yaml.safe_load(f)

    if not data or 'proxies' not in data:
        print('[WARN] 源文件无 proxies 数据，跳过')
        sys.exit(0)

    proxies = data['proxies']
    node_count = len(proxies)

    # 写入临时文件
    with open('$TEMP_FILE', 'w', encoding='utf-8') as f:
        yaml.dump({'proxies': proxies}, f, allow_unicode=True, default_flow_style=False)

    print(f'[OK] 转换完成: {node_count} 个节点 -> $TEMP_FILE')

except Exception as e:
    print(f'[ERROR] 转换失败: {e}', file=sys.stderr)
    sys.exit(1)
" 2>&1

# 检查转换结果
if [ ! -s "$TEMP_FILE" ]; then
    echo "[WARN] 转换结果为空，跳过同步"
    rm -f "$TEMP_FILE"
    exit 0
fi

# 原子替换：先写临时文件，成功后再 mv
mv "$TEMP_FILE" "$TARGET_FILE"
echo "[OK] 节点文件已同步: $TARGET_FILE"

# 通知 Mihomo 重载配置（如果 API 端口开放）
MIHOMO_API="${MIHOMO_API:-http://127.0.0.1:9090}"
MIHOMO_SECRET="${MIHOMO_SECRET:-}"

if curl -s --connect-timeout 3 "$MIHOMO_API" > /dev/null 2>&1; then
    echo "[INFO] 通知 Mihomo 重载..."
    RELOAD_RESULT=$(curl -s -X PUT "$MIHOMO_API/configs" \
        -H "Content-Type: application/json" \
        -H "Authorization: Bearer $MIHOMO_SECRET" \
        -d '{"path":""}' 2>&1 || true)
    echo "[OK] Mihomo 重载已触发: $RELOAD_RESULT"
else
    echo "[INFO] Mihomo API 不可用，依赖文件自动重载 (type: file)"
fi

echo "[$(date '+%Y-%m-%d %H:%M:%S')] 同步完成"